COMPOSE_PROJECT_NAME=selection-committee

# Postgres
POSTGRES_USER=scadmin
POSTGRES_PASSWORD=scadminpass
POSTGRES_DB=selection-committee
POSTGRES_TZ=Europe/Kyiv
PGPORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# RabbitMQ
RABBIT_USER=scrabbit
RABBIT_PASS=scrabbitpass

# MinIO
MINIO_ROOT_USER=scminio
MINIO_ROOT_PASSWORD=scminiopass
MINIO_BUCKET=docs
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Notifications DB
NOTIF_USER=scnotifications
NOTIF_PASS=scnotifications
NOTIF_DB=sc_notifications

# Mailpit
MAILPIT_SMTP=1025
MAILPIT_HTTP=8025

# Observability
ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin

# Service Ports
IDENTITY_SERVICE_PORT=8081
ADMISSION_SERVICE_PORT=8083
DOCUMENTS_SERVICE_PORT=8084
ENVIRONMENT_SERVICE_PORT=8085
NOTIFICATIONS_SERVICE_PORT=8086
GATEWAY_PORT=8080

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_SERVICE_PORT=8087
# Comma-separated list of allowed Telegram chat IDs (empty = allow all)
TELEGRAM_ALLOWED_CHAT_IDS=

# ngrok (required for Telegram webhook in local dev)
# Get your token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
