{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Flag Evaluations Rate (per second)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(feature_flag_evaluations_total{application=\"environment-service\"}[5m])) by (flag_name)",
          "legendFormat": "{{ flag_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Total Evaluations by Flag",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(feature_flag_evaluations_total{application=\"environment-service\"}) by (flag_name)",
          "legendFormat": "{{ flag_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Flag Cache Hit/Miss Ratio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(cache_gets_total{application=\"environment-service\", cache=~\"feature_flag.*\", result=\"hit\"}[5m]))",
          "legendFormat": "Cache Hits",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cache_gets_total{application=\"environment-service\", cache=~\"feature_flag.*\", result=\"miss\"}[5m]))",
          "legendFormat": "Cache Misses",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Feature Flag API Latency (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"environment-service\", uri=~\"/api/v1/feature-flags.*\"}[5m])) by (le, uri))",
          "legendFormat": "p95 {{ uri }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Stale Flag Alerts",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "feature_flag_lifecycle_transitions_total{application=\"environment-service\"}",
          "legendFormat": "{{ flag_key }} : {{ from_status }} → {{ to_status }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Count" }]
          }
        ]
      }
    },
    {
      "title": "Batch Evaluation Response Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"environment-service\", uri=\"/api/v1/feature-flags/evaluate-batch\"}[5m])) by (le))",
          "legendFormat": "p95 evaluate-batch",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"environment-service\", uri=\"/api/v1/feature-flags/evaluate-batch\"}[5m])) by (le))",
          "legendFormat": "p50 evaluate-batch",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "title": "Audit Events Published (Feature Flags)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "sum(increase(feature_flag_audit_events_total{application=\"environment-service\"}[24h])) by (event_type)",
          "legendFormat": "{{ event_type }}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["feature-flags", "environment-service"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Feature Flags",
  "uid": "feature-flags-dashboard",
  "version": 1
}
