        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum by (application) (rate(http_server_requests_seconds_sum{application=~\"$application\"}[5m])) / sum by (application) (rate(http_server_requests_seconds_count{application=~\"$application\"}[5m]))",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "title": "Average Response Time by Service",
      "type": "timeseries"
