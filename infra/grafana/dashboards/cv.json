{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Documents processed per minute, broken down by parse outcome. Target: >= 50 docs/min/instance.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Throughput (docs/min)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(cv_documents_processed_total{job=\"cv-service\"}[1m]) * 60",
          "legendFormat": "{{status}} / {{document_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Total documents processed since process start, by outcome.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Documents Processed (cumulative)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum by (status) (cv_documents_processed_total{job=\"cv-service\"})",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Stage Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Per-stage p50 / p95 / p99 latency for the cv-service pipeline.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Stage Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (stage, le) (rate(cv_processing_seconds_bucket{job=\"cv-service\"}[5m])))",
          "legendFormat": "p50 {{stage}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(cv_processing_seconds_bucket{job=\"cv-service\"}[5m])))",
          "legendFormat": "p95 {{stage}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (stage, le) (rate(cv_processing_seconds_bucket{job=\"cv-service\"}[5m])))",
          "legendFormat": "p99 {{stage}}",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 102,
      "title": "OCR Confidence",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Distribution of mean OCR confidence per parsed document. Lower-bound bands flag low-confidence runs that need human review.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "spectrum" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "id": 4,
      "options": {
        "calculate": false,
        "color": { "scheme": "Spectral", "exponent": 0.5, "fill": "dark-orange", "min": 0, "mode": "scheme", "reverse": false, "scale": "exponential", "scheme": "Oranges", "steps": 64 },
        "tooltip": { "show": true, "yHistogram": true },
        "yAxis": { "axisPlacement": "left", "reverse": false }
      },
      "title": "OCR Confidence Heatmap",
      "type": "heatmap",
      "targets": [
        {
          "expr": "sum by (le, document_type) (rate(cv_ocr_confidence_bucket{job=\"cv-service\"}[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 103,
      "title": "Failures & Resilience",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Failures per second, bucketed by short error code.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 30 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Failure Rate by Reason",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (reason) (rate(cv_documents_failed_total{job=\"cv-service\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "OCR circuit breaker state. 0=closed, 1=half-open, 2=open. Anything > 0 is alert-worthy.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "CLOSED" },
                "1": { "color": "yellow", "index": 1, "text": "HALF-OPEN" },
                "2": { "color": "red", "index": 2, "text": "OPEN" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 30 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "OCR Breaker State",
      "type": "stat",
      "targets": [
        {
          "expr": "cv_ocr_breaker_state{job=\"cv-service\"}",
          "legendFormat": "state",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 104,
      "title": "Queues",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Pending requests on cv.document.requested. Target: < 50 at peak.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Request Queue Depth (cv.document.requested)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"cv.document.requested\"}",
          "legendFormat": "ready",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "description": "Messages dead-lettered to cv.dlq. Anything > 0 needs investigation.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "DLQ Depth (cv.dlq)",
      "type": "stat",
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=\"cv.dlq\"}",
          "legendFormat": "dlq",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["cv", "ocr", "sc"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "CV Service",
  "uid": "sc-cv-service",
  "version": 1
}
